rules_version = '2';

// Bourbon Buddy — Firebase Storage Security Rules
// Users may read/write only files under their own UID-scoped paths.
//   /avatars/{userId}/...           profile photos
//   /labels/{userId}/{entryId}/...  bourbon label photos

service firebase.storage {
  match /b/{bucket}/o {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Gated access (BB-210): uploads additionally require the `approved`
    // custom claim (admin passes too), mirroring firestore.rules. Reads stay
    // owner-only — a pending account can at most see its own files.
    function isApproved() {
      return request.auth != null
             && (request.auth.token.approved == true
                 || request.auth.token.admin == true);
    }

    // Optional guard: images only, capped at 10 MB.
    function isValidImage() {
      return request.resource.size < 10 * 1024 * 1024
             && request.resource.contentType.matches('image/.*');
    }

    match /avatars/{userId}/{allPaths=**} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && isApproved() && isValidImage();
    }

    match /labels/{userId}/{allPaths=**} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && isApproved() && isValidImage();
    }

    // Everything else is denied.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
