rules_version = '2';

// Bourbon Buddy — Firestore Security Rules
// Principle: deny by default; grant the minimum each collection needs.
// See docs/bourbon-buddy-data-model.md for the authoritative summary.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // User profile and ALL user-scoped subcollections
    // (logEntries, pourSessions, wishlistEntries, sightings, articleStates).
    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }

    // Public profile projection (BB-100): the only cross-user-readable view of
    // a user. Holds public fields only (displayName, username, avatar, region,
    // counts) — never email/bio/log/wishlist. Owner-written, mirrored from the
    // private /users doc by UserService. friendCount is also written by the
    // friend callables via the Admin SDK (which bypasses these rules).
    match /publicProfiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // Username reservations (BB-100): one doc per claimed handle, ID = lowercased
    // username, enforcing case-insensitive uniqueness. Create only if it doesn't
    // already exist (Firestore create semantics) and you claim it for yourself;
    // delete only your own (releases the handle). Never updated in place.
    match /usernames/{usernameLower} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn()
                    && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // Shared bourbon catalog: any signed-in user can read or create;
    // only the original creator may update their addition. No deletes.
    match /bourbons/{bourbonId} {
      allow read: if isSignedIn();
      // Basic anti-spam validation (BB-163): a non-empty, bounded name.
      allow create: if isSignedIn()
                    && request.resource.data.createdByUserId == request.auth.uid
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() <= 120;
      allow update: if isSignedIn()
                    && resource.data.createdByUserId == request.auth.uid;
      allow delete: if false;
    }

    // First-class sightings (BB-161). Keyed by bourbonId, owned by spotterUid.
    // Readable only by its spotter for now; friend-visibility is added in BB-110.
    //
    // CREATE is denied here on purpose (BB-163): all creation goes through the
    // `logSighting` callable, which validates input and enforces a per-user
    // daily rate limit via the Admin SDK (which bypasses these rules). The owner
    // may still mark-stale / delete their own sighting, but cannot alter the
    // price, bottle, or createdAt after the fact.
    match /sightings/{sightingId} {
      // Readable by the spotter always, and by the spotter's friends when the
      // sighting is shared with friends (BB-110). Friendship is a reciprocal
      // edge, so the spotter having the reader in their /friends means the two
      // are mutually connected; removing/blocking deletes that edge and revokes
      // access immediately. Private sightings never surface to anyone else.
      allow read: if isSignedIn()
                  && (resource.data.spotterUid == request.auth.uid
                      || (resource.data.visibility == 'friends'
                          && exists(/databases/$(database)/documents/users/$(resource.data.spotterUid)/friends/$(request.auth.uid))));
      allow create: if false;
      allow update: if isSignedIn()
                    && resource.data.spotterUid == request.auth.uid
                    && request.resource.data.spotterUid == resource.data.spotterUid
                    && request.resource.data.bourbonId == resource.data.bourbonId
                    && request.resource.data.price == resource.data.price
                    && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isSignedIn()
                    && resource.data.spotterUid == request.auth.uid;
    }

    // Friend requests (BB-101/102). Visible to the two parties only. CREATE is
    // denied: all creation goes through the `sendFriendRequest` callable, which
    // enforces the self/block/duplicate checks and a per-user daily rate limit.
    // UPDATE is denied too: accept/decline run through `respondToFriendRequest`
    // (Admin SDK). The sender may DELETE their own still-pending request (cancel).
    match /friendRequests/{requestId} {
      allow read: if isSignedIn()
                  && (resource.data.fromUid == request.auth.uid
                      || resource.data.toUid == request.auth.uid);
      allow create: if false;
      allow update: if false;
      allow delete: if isSignedIn()
                    && resource.data.fromUid == request.auth.uid
                    && resource.data.status == 'pending';
    }

    // News articles: read-only for users. Writes come from Cloud Functions
    // via the Admin SDK, which bypasses these rules entirely.
    match /newsArticles/{articleId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Per-user news feed preferences (top-level, keyed by UID).
    match /userNewsPreferences/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Anything not matched above is denied.
  }
}
