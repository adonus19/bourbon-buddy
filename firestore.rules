rules_version = '2';

// Bourbon Buddy — Firestore Security Rules
// Principle: deny by default; grant the minimum each collection needs.
// See docs/bourbon-buddy-data-model.md for the authoritative summary.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // User profile and ALL user-scoped subcollections
    // (logEntries, pourSessions, wishlistEntries, sightings, articleStates).
    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }

    // Shared bourbon catalog: any signed-in user can read or create;
    // only the original creator may update their addition. No deletes.
    match /bourbons/{bourbonId} {
      allow read: if isSignedIn();
      // Basic anti-spam validation (BB-163): a non-empty, bounded name.
      allow create: if isSignedIn()
                    && request.resource.data.createdByUserId == request.auth.uid
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() <= 120;
      allow update: if isSignedIn()
                    && resource.data.createdByUserId == request.auth.uid;
      allow delete: if false;
    }

    // First-class sightings (BB-161). Keyed by bourbonId, owned by spotterUid.
    // Readable only by its spotter for now; friend-visibility is added in BB-110.
    //
    // CREATE is denied here on purpose (BB-163): all creation goes through the
    // `logSighting` callable, which validates input and enforces a per-user
    // daily rate limit via the Admin SDK (which bypasses these rules). The owner
    // may still mark-stale / delete their own sighting, but cannot alter the
    // price, bottle, or createdAt after the fact.
    match /sightings/{sightingId} {
      allow read: if isSignedIn()
                  && resource.data.spotterUid == request.auth.uid;
      allow create: if false;
      allow update: if isSignedIn()
                    && resource.data.spotterUid == request.auth.uid
                    && request.resource.data.spotterUid == resource.data.spotterUid
                    && request.resource.data.bourbonId == resource.data.bourbonId
                    && request.resource.data.price == resource.data.price
                    && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isSignedIn()
                    && resource.data.spotterUid == request.auth.uid;
    }

    // News articles: read-only for users. Writes come from Cloud Functions
    // via the Admin SDK, which bypasses these rules entirely.
    match /newsArticles/{articleId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Per-user news feed preferences (top-level, keyed by UID).
    match /userNewsPreferences/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Anything not matched above is denied.
  }
}
