rules_version = '2';

// Bourbon Buddy — Firestore Security Rules
// Principle: deny by default; grant the minimum each collection needs.
// See docs/bourbon-buddy-data-model.md for the authoritative summary.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Gated access (BB-210): the app is invite-gated. Signing up mints an Auth
    // account, but every data grant below requires the `approved: true` custom
    // claim, set by the access trigger/callables (or the backfill script).
    // Claims ride in the token — checking them costs zero reads. Admin passes
    // too, so the owner can never lock themself out.
    function isApproved() {
      return isSignedIn()
             && (request.auth.token.approved == true
                 || request.auth.token.admin == true);
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // Profile doc (BB-210): readable/writable by its owner EVEN WHILE PENDING —
    // the pending screen watches it and ensureProfile writes it — but the owner
    // may never touch `accessStatus` (only the Admin SDK writes it; a client
    // setting it to "approved" would still lack the claim, but keeping the
    // field honest keeps the UI honest). Admin reads power the approval queue
    // (query: accessStatus == "pending").
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId)
                    && !('accessStatus' in request.resource.data);
      allow update: if isOwner(userId)
                    && !request.resource.data.diff(resource.data)
                        .affectedKeys().hasAny(['accessStatus']);
      allow delete: if isOwner(userId);
    }

    // ALL user-scoped subcollections (logEntries, pourSessions,
    // wishlistEntries, sightings, articleStates, notifications, fcmTokens,
    // settings, friends, blocks, rateLimits): owner AND approved.
    match /users/{userId}/{sub}/{document=**} {
      allow read, write: if isOwner(userId) && isApproved();
    }

    // Owner-managed signup allowlist (BB-210). The admin screen reads/writes
    // it directly (doc ID = lowercased email); the access trigger reads it via
    // the Admin SDK. No other user has any business here.
    match /accessAllowlist/{emailLower} {
      allow read, write: if isAdmin();
    }

    // Public profile projection (BB-100): the only cross-user-readable view of
    // a user. Holds public fields only (displayName, username, avatar, region,
    // counts) — never email/bio/log/wishlist. Owner-written, mirrored from the
    // private /users doc by UserService. friendCount is also written by the
    // friend callables via the Admin SDK (which bypasses these rules).
    //
    // Validated (BB-193) because this doc renders in OTHER users' UI: key
    // allowlist + bounds, username shape matches the app's rules, and a claimed
    // username must be backed by the caller's own /usernames reservation
    // (getAfter: the claim transaction writes both docs atomically). friendCount
    // is bounded, not pinned — the owner's mirror write includes it and the
    // callables (Admin SDK) keep it honest.
    match /publicProfiles/{userId} {
      function validPublicProfile() {
        let d = request.resource.data;
        return d.keys().hasOnly([
            'displayName', 'username', 'usernameLower', 'avatarUrl',
            'homeRegion', 'isDiscoverable', 'friendCount', 'updatedAt'
          ])
          && (d.displayName is string
              && d.displayName.size() >= 1 && d.displayName.size() <= 60)
          && (
            (d.username == null && d.usernameLower == null)
            || (d.username is string
                && d.username.matches('^[a-zA-Z0-9_]{3,20}$')
                && d.usernameLower == d.username.lower()
                && getAfter(/databases/$(database)/documents/usernames/$(d.usernameLower)).data.uid == request.auth.uid)
          )
          && (d.avatarUrl == null
              || (d.avatarUrl is string && d.avatarUrl.size() <= 500
                  && d.avatarUrl.matches('https?://.*')))
          && (d.homeRegion == null
              || (d.homeRegion is string && d.homeRegion.size() <= 80))
          && d.isDiscoverable is bool
          && (d.friendCount is int && d.friendCount >= 0 && d.friendCount <= 100000)
          && d.updatedAt is timestamp;
      }
      allow read: if isApproved();
      allow write: if isOwner(userId) && isApproved() && validPublicProfile();
    }

    // Username reservations (BB-100): one doc per claimed handle, ID = lowercased
    // username, enforcing case-insensitive uniqueness. Create only if it doesn't
    // already exist (Firestore create semantics) and you claim it for yourself;
    // delete only your own (releases the handle). Never updated in place.
    match /usernames/{usernameLower} {
      allow read: if isApproved();
      // Handle format matches the app's rules (3-20, word chars, lowercased
      // key) so junk/squat docs can't be minted outside the claim flow (BB-193).
      allow create: if isApproved()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.keys().hasOnly(['uid', 'createdAt'])
                    && usernameLower.matches('^[a-z0-9_]{3,20}$');
      allow delete: if isApproved()
                    && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // Shared bourbon catalog: any signed-in user can read or create;
    // only the original creator may update their addition. No deletes.
    match /bourbons/{bourbonId} {
      // Field allowlist + per-field bounds (BB-193): the catalog is shared, so
      // no user may park unbounded/foreign data on it. (List ITEMS can't be
      // validated in rules; lists are capped by count and docs by Firestore's
      // 1 MiB limit.)
      function validBourbonData() {
        let d = request.resource.data;
        return d.keys().hasOnly([
            'name', 'nameLowercase', 'nameNormalized', 'aliases', 'canonicalId',
            'distillery', 'bottler', 'category', 'subType', 'ageStatement',
            'isNas', 'proof', 'msrp', 'series', 'upc', 'flavorProfile',
            'flavorEnrichedAt', 'createdAt', 'createdByUserId'
          ])
          && (d.name is string && d.name.size() > 0 && d.name.size() <= 120)
          && (!('nameLowercase' in d)
              || (d.nameLowercase is string && d.nameLowercase.size() <= 160))
          && (!('nameNormalized' in d)
              || (d.nameNormalized is string && d.nameNormalized.size() <= 160))
          && (!('aliases' in d) || (d.aliases is list && d.aliases.size() <= 20))
          && (!('canonicalId' in d) || d.canonicalId == null
              || (d.canonicalId is string && d.canonicalId.size() <= 128))
          && (!('distillery' in d) || d.distillery == null
              || (d.distillery is string && d.distillery.size() <= 120))
          && (!('bottler' in d) || d.bottler == null
              || (d.bottler is string && d.bottler.size() <= 120))
          && (!('category' in d) || d.category == null
              || (d.category is string && d.category.size() <= 40))
          && (!('subType' in d) || d.subType == null
              || (d.subType is string && d.subType.size() <= 40))
          && (!('ageStatement' in d) || d.ageStatement == null
              || d.ageStatement is number)
          && (!('isNas' in d) || d.isNas is bool)
          && (!('proof' in d) || d.proof == null || d.proof is number)
          && (!('msrp' in d) || d.msrp == null || d.msrp is number)
          && (!('series' in d) || d.series == null
              || (d.series is string && d.series.size() <= 120))
          && (!('upc' in d) || (d.upc is list && d.upc.size() <= 20))
          && (!('flavorProfile' in d) || d.flavorProfile == null
              || d.flavorProfile is map)
          && (!('flavorEnrichedAt' in d) || d.flavorEnrichedAt == null
              || d.flavorEnrichedAt is timestamp);
      }
      allow read: if isApproved();
      allow create: if isApproved()
                    && request.resource.data.createdByUserId == request.auth.uid
                    && validBourbonData();
      // The creator may edit their addition (same bounds, and can't reassign
      // authorship/backdate); any signed-in user may append to the crowdsourced
      // UPC index (BB-175) — but ONLY the `upc` field, bounded, so scanning a
      // bottle you (or the AI) didn't create still teaches the index.
      allow update: if isApproved()
                    && (
                      (
                        resource.data.createdByUserId == request.auth.uid
                        && validBourbonData()
                        && !request.resource.data.diff(resource.data)
                            .affectedKeys().hasAny(['createdByUserId', 'createdAt'])
                      )
                      || (
                        request.resource.data.diff(resource.data)
                          .affectedKeys().hasOnly(['upc'])
                        && request.resource.data.upc is list
                        && request.resource.data.upc.size() <= 20
                      )
                    );
      allow delete: if false;
    }

    // First-class sightings (BB-161). Keyed by bourbonId, owned by spotterUid.
    // Readable only by its spotter for now; friend-visibility is added in BB-110.
    //
    // CREATE is denied here on purpose (BB-163): all creation goes through the
    // `logSighting` callable, which validates input and enforces a per-user
    // daily rate limit via the Admin SDK (which bypasses these rules). The owner
    // may still mark-stale / delete their own sighting, but cannot alter the
    // price, bottle, or createdAt after the fact.
    match /sightings/{sightingId} {
      // Readable by the spotter always, and by the spotter's friends when the
      // sighting is shared with friends (BB-110). Friendship is a reciprocal
      // edge, so the spotter having the reader in their /friends means the two
      // are mutually connected; removing/blocking deletes that edge and revokes
      // access immediately. Private sightings never surface to anyone else.
      allow read: if isApproved()
                  && (resource.data.spotterUid == request.auth.uid
                      || (resource.data.visibility == 'friends'
                          && exists(/databases/$(database)/documents/users/$(resource.data.spotterUid)/friends/$(request.auth.uid))));
      allow create: if false;
      // Owner edits are allowlisted to the fields that are legitimately
      // editable after the fact (BB-193). Everything trust-relevant — identity,
      // bottle, price, store, dates, coordinates, and the server-derived
      // presence attestation (BB-191) — is immutable once logged: re-dating or
      // re-locating a sighting would forge freshness/trust signals.
      allow update: if isApproved()
                    && resource.data.spotterUid == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['markedStaleManually', 'visibility', 'notes',
                                  'city', 'state'])
                    && request.resource.data.markedStaleManually is bool
                    && (request.resource.data.visibility == 'private'
                        || request.resource.data.visibility == 'friends')
                    && (request.resource.data.notes == null
                        || (request.resource.data.notes is string
                            && request.resource.data.notes.size() <= 500));
      allow delete: if isApproved()
                    && resource.data.spotterUid == request.auth.uid;
    }

    // Durable price history (BB-202). One immutable point per sighting, minted by
    // the logSighting callable (Admin SDK) so crowd prices survive the 30-day
    // sighting purge. Same read model as /sightings — the spotter always, and the
    // spotter's friends when shared. ALL client writes are denied: points are
    // write-once and never edited or deleted (re-dating/re-pricing would forge the
    // history); the callable and the backfill use the Admin SDK, which bypasses
    // these rules.
    match /priceHistory/{pointId} {
      allow read: if isApproved()
                  && (resource.data.spotterUid == request.auth.uid
                      || (resource.data.visibility == 'friends'
                          && exists(/databases/$(database)/documents/users/$(resource.data.spotterUid)/friends/$(request.auth.uid))));
      allow write: if false;
    }

    // Friend requests (BB-101/102). Visible to the two parties only. CREATE is
    // denied: all creation goes through the `sendFriendRequest` callable, which
    // enforces the self/block/duplicate checks and a per-user daily rate limit.
    // UPDATE is denied too: accept/decline run through `respondToFriendRequest`
    // (Admin SDK). The sender may DELETE their own still-pending request (cancel).
    match /friendRequests/{requestId} {
      allow read: if isApproved()
                  && (resource.data.fromUid == request.auth.uid
                      || resource.data.toUid == request.auth.uid);
      allow create: if false;
      allow update: if false;
      allow delete: if isApproved()
                    && resource.data.fromUid == request.auth.uid
                    && resource.data.status == 'pending';
    }

    // News articles: read-only for users. Writes come from Cloud Functions
    // via the Admin SDK, which bypasses these rules entirely.
    match /newsArticles/{articleId} {
      allow read: if isApproved();
      allow write: if false;
    }

    // Per-user news feed preferences (top-level, keyed by UID).
    match /userNewsPreferences/{userId} {
      allow read, write: if isOwner(userId) && isApproved();
    }

    // Anything not matched above is denied.
  }
}
