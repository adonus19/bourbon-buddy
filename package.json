{
  "name": "bourbon-buddy",
  "version": "0.0.1",
  "author": "Ionic Framework",
  "homepage": "https://ionicframework.com/",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "jest",
    "test:cov": "jest --coverage",
    "lint": "ng lint",
    "build:prod": "ng build --configuration production",
    "build:staging": "ng build --configuration staging",
    "emulators": "firebase emulators:start",
    "emulators:export": "firebase emulators:start --import=./emulator-data --export-on-exit",
    "deploy:hosting": "npm run build:prod && firebase deploy --only hosting",
    "deploy:rules": "firebase deploy --only firestore:rules,storage",
    "deploy:indexes": "firebase deploy --only firestore:indexes",
    "deploy:functions": "firebase deploy --only functions"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "20.3.25",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "20.3.25",
    "@angular/compiler": "20.3.25",
    "@angular/core": "20.3.25",
    "@angular/fire": "^20.0.1",
    "@angular/forms": "20.3.25",
    "@angular/platform-browser": "20.3.25",
    "@angular/platform-browser-dynamic": "20.3.25",
    "@angular/router": "20.3.25",
    "@angular/service-worker": "^20.3.25",
    "@fontsource/dm-sans": "^5.2.8",
    "@fontsource/playfair-display": "^5.2.8",
    "@ionic/angular": "^8.0.0",
    "@zxing/browser": "^0.2.0",
    "chart.js": "^4.5.1",
    "firebase": "^11.10.0",
    "ionicons": "^7.0.0",
    "leaflet": "^1.9.4",
    "ng2-charts": "^9.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-eslint/builder": "20.7.0",
    "@angular-eslint/eslint-plugin": "20.7.0",
    "@angular-eslint/eslint-plugin-template": "20.7.0",
    "@angular-eslint/schematics": "20.7.0",
    "@angular-eslint/template-parser": "20.7.0",
    "@angular/build": "^20.3.28",
    "@angular/cli": "20.3.28",
    "@angular/compiler-cli": "20.3.25",
    "@angular/language-service": "20.3.25",
    "@ionic/angular-toolkit": "^12.0.0",
    "@types/jest": "^30.0.0",
    "@types/leaflet": "^1.9.21",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.16.0",
    "eslint-plugin-import": "^2.29.1",
